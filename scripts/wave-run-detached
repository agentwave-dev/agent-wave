#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 2 ]; then
  echo "usage: scripts/wave-run-detached <lane> <shell-command>" >&2
  exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
lane="$1"
shift
command="$*"
run_id="${WAVE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$lane}"
run_dir="$repo_root/.agent-wave/runtime/$lane/runs/$run_id"
mkdir -p "$run_dir"

printf '%s\n' "$command" > "$run_dir/command.txt"
(
  set +e
  bash -lc "$command" > "$run_dir/stdout.log" 2> "$run_dir/stderr.log"
  code="$?"
  printf '{"run_id":"%s","lane":"%s","exit_code":%s}\n' "$run_id" "$lane" "$code" > "$run_dir/status.json"
  exit "$code"
) &

echo "started $run_id"
echo "$run_dir"
