#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cmd="${1:-help}"

usage() {
  echo "usage: scripts/wave {smoke|audit|status|milestone|context-pack|peek}" >&2
}

case "$cmd" in
  smoke)
    test -f "$repo_root/README.md"
    test -f "$repo_root/docs/roadmap/goals.md"
    test -x "$repo_root/scripts/wave-run-detached"
    echo "wave smoke: ok"
    ;;
  audit)
    "$repo_root/scripts/wave-audit"
    ;;
  status)
    "$repo_root/scripts/wave-status"
    ;;
  milestone)
    "$repo_root/scripts/wave-audit"
    git -C "$repo_root" status --short --branch
    echo "milestone gate: inspect status, tests, and receipt before committing"
    ;;
  context-pack)
    shift || true
    lane=""
    skill=""
    goal=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --lane)
          lane="${2:-}"
          shift 2
          ;;
        --skill)
          skill="${2:-}"
          shift 2
          ;;
        --goal)
          goal="${2:-}"
          shift 2
          ;;
        *)
          echo "unknown context-pack option: $1" >&2
          exit 2
          ;;
      esac
    done
    if [ -z "$lane" ] || [ -z "$skill" ] || [ -z "$goal" ]; then
      echo "usage: scripts/wave context-pack --lane <lane> --skill <skill> --goal <goal>" >&2
      exit 2
    fi
    python - "$repo_root" "$lane" "$skill" "$goal" <<'PY'
import pathlib
import sys

repo = pathlib.Path(sys.argv[1])
lane = sys.argv[2]
skill = sys.argv[3]
goal = sys.argv[4]

lane_path = repo / ".agent-wave" / "lanes" / f"{lane}.yaml"
skill_path = repo / "skills" / skill / "SKILL.md"
out_path = repo / ".agent-wave" / "context" / f"latest_{lane}.md"

if not lane_path.exists():
    raise SystemExit(f"missing lane file: {lane_path.relative_to(repo)}")
if not skill_path.exists():
    raise SystemExit(f"missing skill file: {skill_path.relative_to(repo)}")

def parse_simple_yaml(path):
    data = {}
    current = None
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.rstrip()
        if not line or line.lstrip().startswith("#"):
            continue
        if line.startswith("  - ") and current:
            data.setdefault(current, []).append(line[4:])
            continue
        if ":" in line and not line.startswith(" "):
            key, value = line.split(":", 1)
            key = key.strip()
            value = value.strip()
            current = key
            data[key] = [] if value == "" else value
    return data

lane_data = parse_simple_yaml(lane_path)
required = [
    "lane",
    "tooling_root",
    "target_source_root",
    "runtime_data_root",
    "branch",
    "status",
    "current_goal",
    "allowed_paths",
    "forbidden_paths",
    "read_before_work",
    "last_receipts",
    "known_blockers",
    "completion_budget",
]
missing = [name for name in required if name not in lane_data]
if missing:
    raise SystemExit(f"lane file missing required fields: {', '.join(missing)}")

def as_list(value):
    if isinstance(value, list):
        return value
    if value in ("", "[]"):
        return []
    return [str(value)]

def section(title):
    lines.append("")
    lines.append(f"## {title}")

def bullets(items, empty="None"):
    items = as_list(items)
    if not items:
        lines.append(f"- {empty}")
    else:
        lines.extend(f"- {item}" for item in items)

skill_lines = []
for line in skill_path.read_text(encoding="utf-8").splitlines():
    if line.startswith("# "):
        continue
    skill_lines.append(line)
    if len(skill_lines) >= 70:
        skill_lines.append("- Skill truncated for context budget; open the skill file if directed.")
        break

lines = [
    f"# Context Pack: {lane}",
    "",
    f"Goal: {goal}",
    f"Lane: {lane_data['lane']}",
    f"Branch: {lane_data['branch']}",
    f"Status: {lane_data['status']}",
    f"Tooling root: {lane_data['tooling_root']}",
    f"Target source root: {lane_data['target_source_root']}",
    f"Runtime data root: {lane_data['runtime_data_root']}",
]

section("Token Rules")
bullets([
    "Read state pack first.",
    "Do not restate project history.",
    "Read only target files listed in this context pack.",
    "Do not scan unrelated files.",
    "Do not print full diffs or full files.",
    "Write a heartbeat artifact before deep work.",
    "Write compact completion JSON.",
    "If logs exceed the cap, stop broad exploration and summarize.",
    "Prefer artifact paths over inline logs.",
    "Use summary extraction commands instead of cat/tail.",
])

section("Current Goal")
bullets([lane_data["current_goal"]])

section("Read Before Work")
bullets(lane_data["read_before_work"])

section("Allowed Paths")
bullets(lane_data["allowed_paths"])

section("Forbidden Paths")
bullets(lane_data["forbidden_paths"])

section("Last Receipts")
bullets(lane_data["last_receipts"])

section("Known Blockers")
bullets(lane_data["known_blockers"])

section("Completion Budget")
bullets([lane_data["completion_budget"]])

section(f"Selected Skill: {skill}")
lines.extend(skill_lines)

section("Completion Requirements")
bullets([
    "Write reports/codex_runs/<task>/completion.json or the lane-specific equivalent.",
    "Write a markdown receipt under reports/completions/.",
    "Keep receipts under 120 lines.",
    "List changed files, commands run, tests/build result, blockers, next action, and raw log path only.",
])

if len(lines) > 200:
    lines = lines[:197] + ["", "## Context Budget", "- Context pack truncated to 200 lines."]

out_path.parent.mkdir(parents=True, exist_ok=True)
out_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
print(out_path.relative_to(repo))
PY
    ;;
  peek)
    shift || true
    task=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --task)
          task="${2:-}"
          shift 2
          ;;
        *)
          echo "unknown peek option: $1" >&2
          exit 2
          ;;
      esac
    done
    if [ -z "$task" ]; then
      echo "usage: scripts/wave peek --task <task>" >&2
      exit 2
    fi
    python - "$repo_root" "$task" <<'PY'
import glob
import json
import os
import pathlib
import re
import subprocess
import sys

repo = pathlib.Path(sys.argv[1])
task = sys.argv[2]
safe = re.sub(r"[^A-Za-z0-9_.-]", "_", task)
run_files = sorted(glob.glob(f"/tmp/{safe}_*.run"))

print(f"task: {task}")
if not run_files:
    print("run file: missing")
    raise SystemExit(1)

run_file = pathlib.Path(run_files[-1])
values = {}
for line in run_file.read_text(encoding="utf-8", errors="replace").splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
    elif ":" in line:
        key, value = line.split(":", 1)
    else:
        continue
    values[key.strip().upper()] = value.strip()

log_path = pathlib.Path(values.get("LOG", str(run_file).removesuffix(".run") + ".log"))
done_path = pathlib.Path(values.get("DONE", str(run_file).removesuffix(".run") + ".done"))
completion_path = repo / "reports" / "codex_runs" / task / "completion.json"

print(f"run file: {run_file}")
print(f"log file: {log_path}")
if log_path.exists():
    print(f"log size bytes: {log_path.stat().st_size}")
else:
    print("log size bytes: missing")
print(f"done file: {'present' if done_path.exists() else 'missing'}")
print(f"completion json: {'present' if completion_path.exists() else 'missing'}")

prompt = values.get("PROMPT")
if prompt:
    try:
        result = subprocess.run(["pgrep", "-af", prompt], check=False, text=True, capture_output=True)
        active = [
            line
            for line in result.stdout.splitlines()
            if "pgrep -af" not in line
            and "scripts/wave peek" not in line
            and "python - " not in line
        ]
    except OSError:
        active = []
else:
    active = []
print("active process:")
if active:
    for line in active[:3]:
        print(f"- {line[:200]}")
else:
    print("- none found")

if completion_path.exists():
    try:
        json.loads(completion_path.read_text(encoding="utf-8"))
        print("completion json parse: ok")
    except json.JSONDecodeError as exc:
        print(f"completion json parse: failed at line {exc.lineno}")

if log_path.exists():
    status_terms = []
    pattern = re.compile(r"(token|status|error|failed|passed|complete)", re.IGNORECASE)
    with log_path.open("r", encoding="utf-8", errors="replace") as handle:
        for raw in handle:
            if pattern.search(raw):
                status_terms.append(raw.strip()[:180])
            if len(status_terms) >= 5:
                break
    print("status grep:")
    if status_terms:
        for line in status_terms:
            print(f"- {line}")
    else:
        print("- no token/status lines found")
PY
    ;;
  *)
    usage
    exit 2
    ;;
esac
